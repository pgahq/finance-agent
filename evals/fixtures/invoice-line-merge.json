{
  "cases": [
    {
      "id": "one-line-matches-po-by-description",
      "input": {
        "extractedInvoiceLines": [
          { "description": "PGA Championship catering", "quantity": 1, "totalPrice": "$5,000.00" }
        ],
        "purchaseOrderLines": [
          {
            "lineOrder": 1,
            "purchaseOrderLineId": "PO-LINE-001",
            "description": "2026 PGA Championship - catering services",
            "worktagsReference": [
              { "ID": [{ "$attributes": { "type": "Cost_Center_Reference_ID" }, "$value": "72200" }] },
              { "ID": [{ "$attributes": { "type": "Fund_ID" }, "$value": "FD-001" }] }
            ],
            "spendCategoryReference": {
              "ID": [{ "$attributes": { "type": "Spend_Category_ID" }, "$value": "SC-EVENT" }]
            },
            "shipToAddressId": null
          }
        ],
        "emailBody": null,
        "fallbackIds": {}
      },
      "expected": {
        "lines": [
          {
            "lineOrder": 1,
            "purchaseOrderLineId": "PO-LINE-001",
            "costCenterId": "72200",
            "fundId": "FD-001",
            "spendCategoryId": "SC-EVENT",
            "extendedAmount": 5000
          }
        ]
      }
    },
